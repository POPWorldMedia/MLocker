@page "/Artists"
@using MLocker.WebApp.Services
@inject IMusicService MusicService
@inject NavigationManager NavigationManager

@if (_currentArtist != null)
{
	<Artists_Detail CurrentArtist="@_currentArtist" />
}
else
{
	<Artists_All OnClick="@LoadArtistDetail" ArtistList="_artistList" />
}

@code {
	[SupplyParameterFromQuery(Name = "artist")] public string ArtistParam { get; set; }

	List<string> _artistList = new List<string>();
	string _currentArtist;

	protected override async Task OnInitializedAsync()
	{
		_artistList = await MusicService.GetAllArtists();
		ResolveArtist();
	}

	protected override Task OnParametersSetAsync()
	{
		ResolveArtist();
		return Task.CompletedTask;
	}

	private void ResolveArtist()
	{
		if (_artistList.Count == 0) return;
		_currentArtist = !string.IsNullOrEmpty(ArtistParam)
			? _artistList.SingleOrDefault(x => x == ArtistParam)
			: null;
	}

	protected void LoadArtistDetail(string artist)
	{
		NavigationManager.NavigateTo($"/Artists?artist={Uri.EscapeDataString(artist ?? "")}");
	}
}