@page "/Albums"
@using MLocker.WebApp.Services
@using MLocker.Core.Models
@using Microsoft.AspNetCore.WebUtilities
@inject IMusicService MusicService
@inject NavigationManager NavigationManager

@if (_currentAlbum != null)
{
	<Albums_Detail Album="_currentAlbum" />
}
else
{
	<Albums_All OnClick="@LoadAlbum" AlbumList="_albumList"/>
}

@code {
	[SupplyParameterFromQuery(Name = "artist")] public string ArtistParam { get; set; }
	[SupplyParameterFromQuery(Name = "title")] public string TitleParam { get; set; }

	private List<Album> _albumList = new List<Album>();
	private Album _currentAlbum;

	protected override async Task OnInitializedAsync()
	{
		_albumList = await MusicService.GetAlbums();
	}

	protected override async Task OnParametersSetAsync()
	{
		if (_albumList.Count > 0)
			_currentAlbum = !string.IsNullOrEmpty(TitleParam)
				? _albumList.SingleOrDefault(x => (x.AlbumArtist ?? "") == (ArtistParam ?? "") && (x.Title ?? "") == TitleParam)
				: null;
	}

	protected void LoadAlbum(Album album)
	{
		var url = QueryHelpers.AddQueryString("/Albums", new Dictionary<string, string>
		{
			["artist"] = album.AlbumArtist ?? "",
			["title"] = album.Title ?? ""
		});
		NavigationManager.NavigateTo(url);
	}
}